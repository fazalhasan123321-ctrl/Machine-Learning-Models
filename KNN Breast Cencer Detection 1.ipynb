idean', 'manhattan', 'minkowski'],\\n\",","    \"    'weights'    : ['uniform', 'distance']\\n\",","    \"}\\n\",","    \"grid = GridSearchCV(KNeighborsClassifier(), param_grid, cv=5, scoring='accuracy', n_jobs=-1)\\n\",","    \"grid.fit(X_train_scaled, y_train)\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"id\": \"d9dfa8b6-8d80-4252-8280-c47b2d3283fb\",","   \"metadata\": {},","   \"source\": [","    \"* Instead of manually trying every combination of K, distance metric, and weights — GridSearchCV does it automatically. It tries all combinations (20 × 3 × 2 = 120 combinations), evaluates each with 5-fold CV, and picks the best one. n_jobs=-1 uses all CPU cores to run faster.\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": 59,","   \"id\": \"818f1fe8-178f-4961-956e-c2d928eaa09c\",","   \"metadata\": {},","   \"outputs\": [","    {","     \"name\": \"stdout\",","     \"output_type\": \"stream\",","     \"text\": [","      \"Best Params: {'metric': 'euclidean', 'n_neighbors': 3, 'weights': 'uniform'}\\n\"","     ]","    }","   ],","   \"source\": [","    \"print(\\\"Best Params:\\\", grid.best_params_)\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"id\": \"e2639a07-627b-479a-ac6d-cce7cd1c16d8\",","   \"metadata\": {},","   \"source\": [","    \"* Prints the winning combination — e.g. {'metric': 'euclidean', 'n_neighbors': 7, 'weights': 'distance'}.\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": 60,","   \"id\": \"930dbed8-cd52-4413-b39c-d59a23ce62e2\",","   \"metadata\": {},","   \"outputs\": [],","   \"source\": [","    \"pca = PCA(n_components=2)\\n\",","    \"X_pca = pca.fit_transform(X_train_scaled)\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"id\": \"b32dfbe4-ddfd-4ec1-963e-98fd6db89f31\",","   \"metadata\": {},","   \"source\": [","    \"* PCA (Principal Component Analysis) compresses 30 features down to just 2 — the 2 directions that capture the most 